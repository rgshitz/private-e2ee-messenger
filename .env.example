PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
MONGO_URI=mongodb://127.0.0.1:27017/private_e2ee_messenger
MONGO_CONNECT_RETRIES=12
MONGO_CONNECT_RETRY_MS=2500
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
SERVE_CLIENT_DIST=false
CLIENT_DIST_PATH=client/dist

# Attachments are encrypted in the browser before upload.
# local keeps encrypted blobs on this server. cloudinary stores encrypted blobs in Cloudinary.
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_ATTACHMENT_MB=25

# Required only when STORAGE_DRIVER=cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=private-e2ee-messenger
