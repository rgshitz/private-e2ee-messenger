NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# Public URL of your deployed app, for example:
# https://private-e2ee-messenger.onrender.com
PUBLIC_API_URL=https://your-app.onrender.com

# Leave empty when the client and API are served from the same Render service.
# Set this only if you split the frontend and backend onto different domains.
CLIENT_ORIGIN=

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/private_e2ee_messenger?retryWrites=true&w=majority
MONGO_CONNECT_RETRIES=12
MONGO_CONNECT_RETRY_MS=2500
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

SERVE_CLIENT_DIST=true
CLIENT_DIST_PATH=client/dist

# Attachments are encrypted in the browser before upload.
# In hosted/free environments, use cloudinary because the server filesystem is temporary.
STORAGE_DRIVER=cloudinary
MAX_ATTACHMENT_MB=25
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=private-e2ee-messenger
